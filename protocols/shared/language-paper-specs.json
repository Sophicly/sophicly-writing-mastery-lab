    "short_analysis": "5-10 marks, 1-2 paragraph analytical response",
    "analysis": "10-15 marks, multi-paragraph analytical response with evidence",
    "evaluation": "15-20 marks, extended evaluative response requiring personal judgement",
    "extended_writing": "20-40 marks, full essay structure (intro + body + conclusion)",
    "comparison": "Cross-text comparison requiring references to both sources",
    "choice": "Student chooses one task from multiple options"
  },

